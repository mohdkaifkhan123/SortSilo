// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Permission {
  VIEWER
  EDITOR
}
model User {
  id              Int     @id @default(autoincrement())
  email           String  @unique
  name            String?
  password        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  files           File[]
  folder          Folder[]
  sharedSender    Shared[] @relation("SendShares")
  receivedShares  Shared[] @relation("ReceivedShares")

}

model File{
    id        Int    @id@default(autoincrement())
    fileSize  Int   
    fileName  String
    fileUrl   String 
    UserId    Int
    mimetype  String?
    deletedAt DateTime?
    user      User  @relation(fields:[UserId],references:[id])
    FolderId  Int?
    folder    Folder? @relation(fields:[FolderId],references:[id])
    shares    Shared[]
}

model Folder{
  id         Int    @id@default(autoincrement())
  folderName String
  UserId     Int
  user       User  @relation(fields:[UserId],references:[id])
  parentId   Int?
  parent     Folder? @relation("NestedArch",fields:[parentId],references:[id])
  subFolders Folder[] @relation("NestedArch")
  files      File[]
  shares     Shared[]
}

model Shared{
  id             Int   @id@default(autoincrement())
  fileId         Int?   
  file           File?  @relation(fields:[fileId],references:[id])
  folderId       Int?
  folder         Folder? @relation(fields:[folderId],references:[id])
  senderUserId   Int
  sender         User  @relation("SendShares",fields:[senderUserId],references:[id])
  receiverUserId Int
  receiver       User  @relation("ReceivedShares",fields:[receiverUserId],references:[id])
  createdAt      DateTime?
  permission     Permission
}